# ============================================================
# Marcher Coffee — Ortam dosyası (proje kökü)
#
# CANLI: .env oluşturmadan docker compose up -d --build yeterli
#        (bu dosyadaki production varsayılanları kullanılır)
#
# Özelleştirmek için: cp .env.example .env && nano .env
# ============================================================

# --- Database (Docker iç ağı) ---
POSTGRES_USER=marcher
POSTGRES_PASSWORD=marcher_secret
POSTGRES_DB=marcher_coffee
DATABASE_URL=postgresql://marcher:marcher_secret@postgres:5432/marcher_coffee?schema=public

# --- Backend ---
NODE_ENV=production
PORT=5050
JWT_SECRET=change-me-run-openssl-rand-base64-64
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://marchercoffee.com
COOKIE_DOMAIN=.marchercoffee.com
UPLOAD_DIR=uploads

# --- Frontend (build-time) ---
VITE_API_URL=https://servis.marchercoffee.com/api
VITE_SITE_URL=https://marchercoffee.com

# --- Admin seed ---
ADMIN_EMAIL=admin@marchercoffee.com
ADMIN_PASSWORD=Marcher2026!
ADMIN_NAME=Marcher Admin

# ============================================================
# GELİŞTİRME — sadece local npm run dev için .env'yi şöyle ayarlayın:
# ============================================================
# NODE_ENV=development
# DATABASE_URL=postgresql://marcher:marcher_secret@localhost:5432/marcher_coffee?schema=public
# CORS_ORIGIN=http://localhost:5055
# COOKIE_DOMAIN=
# VITE_API_URL=http://localhost:5050/api
# VITE_SITE_URL=http://localhost:5055
