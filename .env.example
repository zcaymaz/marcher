# ============================================================
# Marcher Coffee — Tek ortam dosyası (proje kökü: marcher/.env)
# Kurulum: cp .env.example .env
# ============================================================

# --- Database ---
POSTGRES_USER=marcher
POSTGRES_PASSWORD=marcher_secret
POSTGRES_DB=marcher_coffee

# Geliştirme: localhost | Canlı Docker: postgres
DATABASE_URL=postgresql://marcher:marcher_secret@localhost:5432/marcher_coffee?schema=public

# --- Backend ---
NODE_ENV=development
PORT=5050
JWT_SECRET=Osb5NLjFmqvpkr0BmeG5nRPcFjkox1ZzIM4i0axhlzFUpMmYO4WTC9h+4SoTYdodyVBBEPbb3MInnDdqAxdXY7w==
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://marchercoffee.com
COOKIE_DOMAIN=.marchercoffee.com
UPLOAD_DIR=uploads

# --- Frontend ---
# Canlı: site domaini üzerinden nginx /api ve /uploads proxy eder
VITE_API_URL=https://marchercoffee.com/api
VITE_SITE_URL=https://marchercoffee.com

# --- Admin seed ---
ADMIN_EMAIL=admin@marchercoffee.com
ADMIN_PASSWORD=Marcher2026!
ADMIN_NAME=Marcher Admin

# ============================================================
# CANLI (production) — aşağıdaki değerlerle değiştirin:
